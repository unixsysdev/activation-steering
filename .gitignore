# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Trained vectors / figures
# The grit artifacts are small (~640K) so they ARE committed.
# Large regenerable figures stay out.
figures/
*.png

# Model weights (never commit — download separately)
*.safetensors
*.bin
*.gguf
# ...but our small steering vectors are committed:
!steering_vectors/*.pt
!vectors/*.svec
!vectors/*.json

# HuggingFace cache
.cache/

# Misc
*.log
.DS_Store
